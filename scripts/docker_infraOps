#!/usr/bin/env bash
set -e

###########################################
# 🎨 Colors & Spinner Utilities
###########################################
RED="\033[0;31m"
GREEN="\033[0;32m"
CYAN="\033[0;36m"
PURPLE="\033[0;35m"
YELLOW="\033[1;33m"
NC="\033[0m"

spinner() {
  local message=$1
  local pid=${2:-$!}
  local spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    i=$(( (i+1) % 10 ))
    printf "\r${CYAN}%s${NC} %s" "${spin:$i:1}" "$message"
    sleep .1
  done
  wait "$pid" 2>/dev/null || true
  printf "\r${GREEN}✔${NC} %s\n" "$message"
}

banner() {
  echo -e "${PURPLE}"
  echo "╔══════════════════════════════════════════════════════╗"
  echo "║ 🛠️  docker-infraOps — INFRA OPS LAB v1.0             ║"
  echo "║ 📈 Metrics + Logs + Alerts + Backups + Object Store  ║"
  echo "╚══════════════════════════════════════════════════════╝"
  echo -e "${NC}"
}

###########################################
# 🧩 Args
###########################################
PROJECT_NAME=""
START_AFTER=true

usage() {
  echo -e "${RED}❌ Usage:${NC} bash scripts/docker_infraOps <project-name> [--no-start]"
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

for arg in "$@"; do
  case "$arg" in
    --no-start) START_AFTER=false ;;
    -*)
      usage
      exit 1
      ;;
    *)
      if [ -z "$PROJECT_NAME" ]; then
        PROJECT_NAME="$arg"
      fi
      ;;
  esac
done

[ -z "$PROJECT_NAME" ] && { usage; exit 1; }

###########################################
# 🧰 Helpers
###########################################
compose_cmd() {
  if docker compose version >/dev/null 2>&1; then
    echo "docker compose"
  else
    echo "docker-compose"
  fi
}

rand() {
  local n="${1:-24}"
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex "$n"
    return 0
  fi
  python3 - <<PY
import secrets
print(secrets.token_hex(${n}))
PY
}

handle_existing() {
  local path="$1"
  if [ -e "$path" ]; then
    echo -e "${YELLOW}⚠️  '$path' already exists.${NC}"
    select choice in "Overwrite" "Keep" "Delete"; do
      case $choice in
        Overwrite)
          echo "📝 Overwriting $path..."
          rm -rf "$path"
          mkdir -p "$path"
          break
          ;;
        Keep)
          echo "👌 Keeping existing $path"
          break
          ;;
        Delete)
          echo "🗑️ Deleting $path..."
          rm -rf "$path"
          read -r -p "Recreate '$path'? (y/n): " recreate
          [[ "$recreate" =~ ^[Yy]$ ]] && mkdir -p "$path"
          break
          ;;
      esac
    done
  else
    mkdir -p "$path"
  fi
}

###########################################
# 🚀 INIT PROJECT
###########################################
banner
handle_existing "$PROJECT_NAME"
cd "$PROJECT_NAME"

ROOT_DIR="$(pwd)"
COMPOSE="$(compose_cmd)"

handle_existing "config/prometheus/rules"
handle_existing "config/alertmanager"
handle_existing "config/grafana/provisioning/datasources"
handle_existing "config/grafana/provisioning/dashboards"
handle_existing "config/loki"
handle_existing "config/vector"
handle_existing "config/blackbox"
handle_existing "demo-app"
handle_existing "docs"
handle_existing "scripts"
handle_existing "backups"

###########################################
# 🧾 Git hygiene
###########################################
cat <<'EOF' > .gitignore
.env
backups/
data/
*.log
.DS_Store
EOF

###########################################
# 🔐 Env
###########################################
MINIO_ROOT_PASSWORD="$(rand 16)"
GRAFANA_ADMIN_PASSWORD="$(rand 12)"
RESTIC_PASSWORD="$(rand 16)"

cat <<EOF > .env
# Localhost bindings (change ports if you have conflicts)
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
MAILPIT_UI_PORT=8025
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
DEMO_APP_PORT=8088

# Grafana auth
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET_RESTIC=restic

# Restic (backup encryption password)
RESTIC_PASSWORD=${RESTIC_PASSWORD}
EOF

cat <<'EOF' > .env.example
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
