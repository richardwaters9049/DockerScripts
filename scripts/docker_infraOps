cat <<'EOF' > config/grafana/provisioning/datasources/datasources.yml
apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    uid: PROM
    isDefault: true

  - name: Loki
    type: loki
    access: proxy
    url: http://loki:3100
    uid: LOKI
EOF

cat <<'EOF' > config/grafana/provisioning/dashboards/dashboards.yml
apiVersion: 1

providers:
  - name: default
    folder: InfraOps Lab
    type: file
    disableDeletion: true
    editable: false
    options:
      path: /etc/grafana/provisioning/dashboards
EOF

cat <<'EOF' > config/grafana/provisioning/dashboards/infraops-lab.json
{
  "uid": "infraops-lab",
  "title": "InfraOps Lab",
  "tags": ["infra", "ops", "lab"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "demo-app up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        { "expr": "max(up{job=\\\"demo-app\\\"})", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [ { "color": "red" }, { "color": "green", "value": 1 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal" }
    },
    {
      "type": "stat",
      "title": "probe success",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        { "expr": "min(probe_success)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "red" }, { "color": "green", "value": 1 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal" }
    },
    {
      "type": "timeseries",
      "title": "demo-app 5xx rate (%)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
