#!/usr/bin/env bash
set -e

###########################################
# 🎨 Colors & Spinner Utilities
###########################################
RED="\033[0;31m"
GREEN="\033[0;32m"
CYAN="\033[0;36m"
PURPLE="\033[0;35m"
YELLOW="\033[1;33m"
NC="\033[0m"

spinner() {
  local message=$1
  local pid=${2:-$!}
  local spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    i=$(( (i+1) % 10 ))
    printf "\r${CYAN}%s${NC} %s" "${spin:$i:1}" "$message"
    sleep .1
  done
  wait "$pid" 2>/dev/null
  local status=$?
  if [ "$status" -eq 0 ]; then
    printf "\r${GREEN}✔${NC} %s\n" "$message"
  else
    printf "\r${RED}✖${NC} %s\n" "$message"
  fi
  return "$status"
}

banner() {
  echo -e "${PURPLE}"
  echo "╔══════════════════════════════════════════════════════╗"
  echo "║ 🛠️  docker-infraOps — INFRA OPS LAB v1.0             ║"
  echo "║ 📈 Metrics + Logs + Alerts + Backups + Object Store  ║"
  echo "╚══════════════════════════════════════════════════════╝"
  echo -e "${NC}"
}

###########################################
# 🧩 Args
###########################################
PROJECT_NAME=""
START_AFTER=true

usage() {
  echo -e "${RED}❌ Usage:${NC} bash scripts/docker_infraOps <project-name> [--no-start]"
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

for arg in "$@"; do
  case "$arg" in
    --no-start) START_AFTER=false ;;
    -*)
      usage
      exit 1
      ;;
    *)
      if [ -z "$PROJECT_NAME" ]; then
        PROJECT_NAME="$arg"
      fi
      ;;
  esac
done

[ -z "$PROJECT_NAME" ] && { usage; exit 1; }

###########################################
# 🧰 Helpers
###########################################
compose_cmd() {
  if docker compose version >/dev/null 2>&1; then
    echo "docker compose"
  else
    echo "docker-compose"
  fi
}

port_available() {
  local port="$1"

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$port" <<'PY'
import socket, sys
port = int(sys.argv[1])
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
try:
  s.bind(("127.0.0.1", port))
except OSError:
  raise SystemExit(1)
finally:
  try:
    s.close()
  except Exception:
    pass
raise SystemExit(0)
PY
    return $?
  fi

  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1 && return 1
    return 0
  fi

  # No reliable checker available; assume it's ok.
  return 0
}

port_reserved() {
  local port="$1"
  shift || true
  local reserved
  for reserved in "${RESERVED_PORTS[@]}"; do
    [ "$reserved" = "$port" ] && return 0
  done
  return 1
}

reserve_port() {
  local port="$1"
  RESERVED_PORTS+=("$port")
}

random_free_port() {
  if command -v python3 >/dev/null 2>&1; then
    python3 - <<'PY'
import socket
import sys
try:
  s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
  s.bind(("127.0.0.1", 0))
  print(s.getsockname()[1])
  s.close()
except OSError:
  raise SystemExit(1)
PY
    return 0
  fi
  return 1
}

choose_port() {
  local preferred="$1"
  local label="$2"
  local out_var="${3:-}"

  if [ -z "$out_var" ]; then
    echo -e "${RED}❌ choose_port missing out-var for ${label}.${NC}" >&2
    exit 1
  fi

  local port="$preferred"
  local tries=0

  # Keep this fast: spawning python per port is expensive on macOS.
  # Try a short contiguous range, then fall back to a random free port.
  while [ "$tries" -lt 50 ]; do
    if port_available "$port" && ! port_reserved "$port"; then
      reserve_port "$port"
      printf -v "$out_var" "%s" "$port"
      return 0
    fi
    port=$((port + 1))
    tries=$((tries + 1))
  done

  echo -e "${RED}❌ Could not find a free port for ${label} starting at ${preferred}.${NC}" >&2

  if command -v python3 >/dev/null 2>&1; then
    echo -e "${YELLOW}ℹ️  Falling back to a random free port for ${label}.${NC}" >&2
    for _ in $(seq 1 50); do
      port="$(random_free_port)" || break
      if ! port_reserved "$port"; then
        reserve_port "$port"
        printf -v "$out_var" "%s" "$port"
        return 0
      fi
    done
  fi

  echo -e "${YELLOW}⚠️  Using preferred port ${preferred} for ${label} (availability check failed).${NC}" >&2
  printf -v "$out_var" "%s" "$preferred"
  return 0
}

ensure_docker_running() {
  command -v docker >/dev/null 2>&1 || {
    echo -e "${RED}❌ Docker CLI not found. Install Docker Desktop (macOS) or Docker Engine.${NC}"
    exit 1
  }

  if docker info >/dev/null 2>&1; then
    return 0
  fi

  echo -e "${YELLOW}⚠️  Docker daemon is not running.${NC}"

  if [[ "${OSTYPE:-}" == darwin* ]] && command -v open >/dev/null 2>&1; then
    echo -e "${CYAN}▶ Starting Docker Desktop...${NC}"
    open -a Docker >/dev/null 2>&1 || true

    (
      for _ in $(seq 1 180); do
        docker info >/dev/null 2>&1 && exit 0
        sleep 1
      done
      exit 1
    ) & spinner "Waiting for Docker daemon" $! || {
      echo -e "${RED}❌ Docker did not become ready within 3 minutes.${NC}"
      echo -e "${YELLOW}Tip:${NC} open Docker Desktop, wait until it says “Engine running”, then rerun."
      exit 1
    }

    return 0
  fi

  echo -e "${RED}❌ Start Docker, then rerun this script.${NC}"
  exit 1
}

rand() {
  local n="${1:-24}"
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex "$n"
    return 0
  fi
  python3 - <<PY
import secrets
print(secrets.token_hex(${n}))
PY
}

handle_existing() {
  local path="$1"
  if [ -e "$path" ]; then
    echo -e "${YELLOW}⚠️  '$path' already exists.${NC}"
    select choice in "Overwrite" "Keep" "Delete"; do
      case $choice in
        Overwrite)
          echo "📝 Overwriting $path..."
          rm -rf "$path"
          mkdir -p "$path"
          break
          ;;
        Keep)
          echo "👌 Keeping existing $path"
          break
          ;;
        Delete)
          echo "🗑️ Deleting $path..."
          rm -rf "$path"
          read -r -p "Recreate '$path'? (y/n): " recreate
          [[ "$recreate" =~ ^[Yy]$ ]] && mkdir -p "$path"
          break
          ;;
      esac
    done
  else
    mkdir -p "$path"
  fi
}

###########################################
# 🚀 INIT PROJECT
###########################################
banner
handle_existing "$PROJECT_NAME"
cd "$PROJECT_NAME"

ROOT_DIR="$(pwd)"
COMPOSE="$(compose_cmd)"
if [ "$START_AFTER" = true ]; then
  ensure_docker_running
fi

handle_existing "config/prometheus/rules"
handle_existing "config/alertmanager"
handle_existing "config/grafana/provisioning/datasources"
handle_existing "config/grafana/provisioning/dashboards"
handle_existing "config/loki"
handle_existing "config/vector"
handle_existing "config/blackbox"
handle_existing "demo-app"
handle_existing "docs"
handle_existing "scripts"
handle_existing "backups"

###########################################
# 🧾 Git hygiene
###########################################
cat <<'EOF' > .gitignore
.env
backups/
data/
*.log
.DS_Store
EOF

###########################################
# 🔐 Env
###########################################
RESERVED_PORTS=()

DEFAULT_GRAFANA_PORT=3000
DEFAULT_PROMETHEUS_PORT=9090
DEFAULT_ALERTMANAGER_PORT=9093
DEFAULT_MAILPIT_UI_PORT=8025
DEFAULT_MINIO_PORT=9000
DEFAULT_MINIO_CONSOLE_PORT=9001
DEFAULT_DEMO_APP_PORT=8088

choose_port "$DEFAULT_GRAFANA_PORT" "grafana" GRAFANA_PORT
choose_port "$DEFAULT_PROMETHEUS_PORT" "prometheus" PROMETHEUS_PORT
choose_port "$DEFAULT_ALERTMANAGER_PORT" "alertmanager" ALERTMANAGER_PORT
choose_port "$DEFAULT_MAILPIT_UI_PORT" "mailpit" MAILPIT_UI_PORT
choose_port "$DEFAULT_MINIO_PORT" "minio" MINIO_PORT
choose_port "$DEFAULT_MINIO_CONSOLE_PORT" "minio-console" MINIO_CONSOLE_PORT
choose_port "$DEFAULT_DEMO_APP_PORT" "demo-app" DEMO_APP_PORT

MINIO_ROOT_PASSWORD="$(rand 16)"
GRAFANA_ADMIN_PASSWORD="$(rand 12)"
RESTIC_PASSWORD="$(rand 16)"

echo -e "${CYAN}🔌 Selected ports:${NC}"
echo "  Grafana:       ${GRAFANA_PORT}"
echo "  Prometheus:    ${PROMETHEUS_PORT}"
echo "  Alertmanager:  ${ALERTMANAGER_PORT}"
echo "  Mailpit:       ${MAILPIT_UI_PORT}"
echo "  MinIO API:     ${MINIO_PORT}"
echo "  MinIO Console: ${MINIO_CONSOLE_PORT}"
echo "  Demo app:      ${DEMO_APP_PORT}"
echo

cat <<EOF > .env
# Localhost bindings (change ports if you have conflicts)
GRAFANA_PORT=${GRAFANA_PORT}
PROMETHEUS_PORT=${PROMETHEUS_PORT}
ALERTMANAGER_PORT=${ALERTMANAGER_PORT}
MAILPIT_UI_PORT=${MAILPIT_UI_PORT}
MINIO_PORT=${MINIO_PORT}
MINIO_CONSOLE_PORT=${MINIO_CONSOLE_PORT}
DEMO_APP_PORT=${DEMO_APP_PORT}

# Image overrides (use if a registry is blocked or you have an internal mirror)
PYTHON_IMAGE=python:3.12-slim
PROMETHEUS_IMAGE=prom/prometheus:v2.52.0
ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
GRAFANA_IMAGE=grafana/grafana:11.1.0
LOKI_IMAGE=grafana/loki:3.1.1
VECTOR_IMAGE=timberio/vector:0.41.1-alpine
BLACKBOX_IMAGE=prom/blackbox-exporter:v0.25.0
MAILPIT_IMAGE=axllent/mailpit:v1.21
MINIO_IMAGE=minio/minio:RELEASE.2025-01-20T14-49-07Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-01-17T23-25-50Z
LOADGEN_IMAGE=curlimages/curl:8.10.1
RESTIC_IMAGE=restic/restic:0.17.1
CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.55.1

# Grafana auth
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET_RESTIC=restic

# Restic (backup encryption password)
RESTIC_PASSWORD=${RESTIC_PASSWORD}
EOF

cat <<'EOF' > .env.example
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
MAILPIT_UI_PORT=8025
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
DEMO_APP_PORT=8088

PYTHON_IMAGE=python:3.12-slim
PROMETHEUS_IMAGE=prom/prometheus:v2.52.0
ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
GRAFANA_IMAGE=grafana/grafana:11.1.0
LOKI_IMAGE=grafana/loki:3.1.1
VECTOR_IMAGE=timberio/vector:0.41.1-alpine
BLACKBOX_IMAGE=prom/blackbox-exporter:v0.25.0
MAILPIT_IMAGE=axllent/mailpit:v1.21
MINIO_IMAGE=minio/minio:RELEASE.2025-01-20T14-49-07Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-01-17T23-25-50Z
LOADGEN_IMAGE=curlimages/curl:8.10.1
RESTIC_IMAGE=restic/restic:0.17.1
CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.55.1

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_RESTIC=restic

RESTIC_PASSWORD=change-me
EOF

###########################################
# 🐳 Compose
###########################################
cat <<'EOF' > docker-compose.yml
services:
  prometheus:
    image: ${PROMETHEUS_IMAGE:-prom/prometheus:v2.52.0}
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
    volumes:
      - ./config/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./config/prometheus/rules:/etc/prometheus/rules:ro
      - prometheus_data:/prometheus
    ports:
      - "127.0.0.1:${PROMETHEUS_PORT:-9090}:9090"
    restart: unless-stopped
    depends_on:
      - blackbox
      - demo-app
    networks: [ops]

  alertmanager:
    image: ${ALERTMANAGER_IMAGE:-prom/alertmanager:v0.27.0}
    command:
      - "--config.file=/etc/alertmanager/alertmanager.yml"
    volumes:
      - ./config/alertmanager/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro
    ports:
      - "127.0.0.1:${ALERTMANAGER_PORT:-9093}:9093"
    restart: unless-stopped
    networks: [ops]

  grafana:
    image: ${GRAFANA_IMAGE:-grafana/grafana:11.1.0}
    environment:
      GF_SECURITY_ADMIN_USER: "${GRAFANA_ADMIN_USER:-admin}"
      GF_SECURITY_ADMIN_PASSWORD: "${GRAFANA_ADMIN_PASSWORD:-admin}"
      GF_USERS_ALLOW_SIGN_UP: "false"
    volumes:
      - grafana_data:/var/lib/grafana
      - ./config/grafana/provisioning:/etc/grafana/provisioning:ro
    ports:
      - "127.0.0.1:${GRAFANA_PORT:-3000}:3000"
    restart: unless-stopped
    depends_on:
      - prometheus
      - loki
    networks: [ops]

  loki:
    image: ${LOKI_IMAGE:-grafana/loki:3.1.1}
    command: ["-config.file=/etc/loki/loki.yml"]
    volumes:
      - ./config/loki/loki.yml:/etc/loki/loki.yml:ro
      - loki_data:/loki
    restart: unless-stopped
    networks: [ops]

  vector:
    image: ${VECTOR_IMAGE:-timberio/vector:0.41.1-alpine}
    command: ["--config", "/etc/vector/vector.toml"]
    volumes:
      - ./config/vector/vector.toml:/etc/vector/vector.toml:ro
      - /var/run/docker.sock:/var/run/docker.sock
    restart: unless-stopped
    depends_on: [loki]
    networks: [ops]

  cadvisor:
    image: ${CADVISOR_IMAGE:-ghcr.io/google/cadvisor:0.55.1}
    profiles: ["extras"]
    privileged: true
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:rw
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
    restart: unless-stopped
    networks: [ops]

  blackbox:
    image: ${BLACKBOX_IMAGE:-prom/blackbox-exporter:v0.25.0}
    command: ["--config.file=/etc/blackbox/blackbox.yml"]
    volumes:
      - ./config/blackbox/blackbox.yml:/etc/blackbox/blackbox.yml:ro
    restart: unless-stopped
    networks: [ops]

  demo-app:
    build:
      context: ./demo-app
      args:
        PYTHON_IMAGE: "${PYTHON_IMAGE:-python:3.12-slim}"
    environment:
      FAILURE_RATE: "0.05"
    ports:
      - "127.0.0.1:${DEMO_APP_PORT:-8088}:8080"
    restart: unless-stopped
    networks: [ops]

  loadgen:
    image: ${LOADGEN_IMAGE:-curlimages/curl:8.10.1}
    command: ["sh", "-c", "while true; do curl -fsS http://demo-app:8080/ >/dev/null || true; sleep 0.2; done"]
    restart: unless-stopped
    depends_on: [demo-app]
    networks: [ops]

  mailpit:
    image: ${MAILPIT_IMAGE:-axllent/mailpit:v1.21}
    environment:
      MP_SMTP_AUTH_ACCEPT_ANY: "true"
      MP_SMTP_AUTH_ALLOW_INSECURE: "true"
    ports:
      - "127.0.0.1:${MAILPIT_UI_PORT:-8025}:8025"
      - "127.0.0.1:1025:1025"
    restart: unless-stopped
    networks: [ops]

  minio:
    image: ${MINIO_IMAGE:-minio/minio:RELEASE.2025-01-20T14-49-07Z}
    command: ["server", "/data", "--console-address", ":9001"]
    environment:
      MINIO_ROOT_USER: "${MINIO_ROOT_USER:-minioadmin}"
      MINIO_ROOT_PASSWORD: "${MINIO_ROOT_PASSWORD:-minioadmin}"
    volumes:
      - minio_data:/data
    ports:
      - "127.0.0.1:${MINIO_PORT:-9000}:9000"
      - "127.0.0.1:${MINIO_CONSOLE_PORT:-9001}:9001"
    restart: unless-stopped
    networks: [ops]

  minio-init:
    image: ${MINIO_MC_IMAGE:-minio/mc:RELEASE.2025-01-17T23-25-50Z}
    depends_on: [minio]
    entrypoint: ["/bin/sh", "-c"]
    command: >
      "until mc alias set local http://minio:9000 ${MINIO_ROOT_USER} ${MINIO_ROOT_PASSWORD} >/dev/null 2>&1; do sleep 1; done;
       mc mb --ignore-existing local/${MINIO_BUCKET_RESTIC};
       mc anonymous set none local/${MINIO_BUCKET_RESTIC};
       echo '✅ MinIO bucket ready: ${MINIO_BUCKET_RESTIC}'"
    networks: [ops]

  restic:
    profiles: ["tools"]
    image: ${RESTIC_IMAGE:-restic/restic:0.17.1}
    environment:
      RESTIC_PASSWORD: "${RESTIC_PASSWORD}"
      AWS_ACCESS_KEY_ID: "${MINIO_ROOT_USER}"
      AWS_SECRET_ACCESS_KEY: "${MINIO_ROOT_PASSWORD}"
      RESTIC_REPOSITORY: "s3:http://minio:9000/${MINIO_BUCKET_RESTIC}/repo"
    volumes:
      - prometheus_data:/data/prometheus:ro
      - grafana_data:/data/grafana:ro
      - loki_data:/data/loki:ro
      - ./config:/data/config:ro
      - ./backups:/restore
    depends_on: [minio-init]
    networks: [ops]

volumes:
  prometheus_data:
  grafana_data:
  loki_data:
  minio_data:

networks:
  ops:
    driver: bridge
EOF

###########################################
# 📈 Prometheus
###########################################
cat <<'EOF' > config/prometheus/prometheus.yml
global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/rules/*.yml

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["prometheus:9090"]

  - job_name: cadvisor
    static_configs:
      - targets: ["cadvisor:8080"]

  - job_name: demo-app
    metrics_path: /metrics
    static_configs:
      - targets: ["demo-app:8080"]

  - job_name: blackbox-http
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
          - http://demo-app:8080/health
          - http://grafana:3000/api/health
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox:9115
EOF

cat <<'EOF' > config/prometheus/rules/alerts.yml
groups:
  - name: demo-app
    rules:
      - alert: DemoAppDown
        expr: up{job="demo-app"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "demo-app is down"
          description: "Prometheus cannot scrape demo-app for 2 minutes."

      - alert: DemoAppHigh5xxRate
        expr: |
          (
            sum(rate(demo_app_requests_total{status=~"5.."}[5m]))
            /
            clamp_min(sum(rate(demo_app_requests_total[5m])), 1)
          ) > 0.05
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "High 5xx rate on demo-app"
          description: "More than 5% of requests are 5xx over the last 5 minutes."
EOF

###########################################
# 🚨 Alertmanager
###########################################
cat <<'EOF' > config/alertmanager/alertmanager.yml
global:
  smtp_smarthost: "mailpit:1025"
  smtp_from: "alertmanager@ops.local"
  smtp_require_tls: false

route:
  receiver: "email-oncall"
  group_by: ["alertname", "job"]
  group_wait: 10s
  group_interval: 1m
  repeat_interval: 2h

receivers:
  - name: "email-oncall"
    email_configs:
      - to: "oncall@ops.local"
        send_resolved: true
EOF

