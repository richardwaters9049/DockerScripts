{
  "uid": "infraops-lab",
  "title": "InfraOps Lab",
  "tags": ["infra", "ops", "lab"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "demo-app up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        { "expr": "max(up{job=\\\"demo-app\\\"})", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "mappings": [], "thresholds": { "mode": "absolute", "steps": [ { "color": "red" }, { "color": "green", "value": 1 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal" }
    },
    {
      "type": "stat",
      "title": "probe success",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        { "expr": "min(probe_success)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "red" }, { "color": "green", "value": 1 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal" }
    },
    {
      "type": "timeseries",
      "title": "demo-app 5xx rate (%)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        {
          "expr": "100 * (sum(rate(demo_app_requests_total{status=~\\\"5..\\\"}[5m])) / clamp_min(sum(rate(demo_app_requests_total[5m])), 1))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "demo-app latency p95 (s)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(demo_app_request_duration_seconds_bucket{path=\\\"/\\\"}[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top container CPU (rate/sec)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        { "expr": "topk(10, sum(rate(container_cpu_usage_seconds_total{image!=\\\"\\\"}[5m])) by (name))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top container memory (bytes)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PROM" },
      "targets": [
        { "expr": "topk(10, max(container_memory_working_set_bytes{image!=\\\"\\\"}) by (name))", "refId": "A" }
      ]
    },
    {
      "type": "logs",
      "title": "demo-app logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "LOKI" },
      "targets": [
        { "expr": "{service=\\\"demo-app\\\"}" , "refId": "A" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
